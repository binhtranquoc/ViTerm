{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ViTerm",
  "version": "0.1.0",
  "identifier": "com.quocbinhtran.qbase",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ViTerm",
        "visible": false,
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      },
      {
        "label": "splash",
        "title": "Loading ViTerm",
        "url": "/splashscreen.html",
        "width": 1280,
        "height": 800,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
